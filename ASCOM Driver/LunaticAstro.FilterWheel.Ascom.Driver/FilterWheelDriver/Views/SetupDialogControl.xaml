<UserControl x:Class="ASCOM.LunaticAstro.FilterWheel.FilterWheelDriver.Views.SetupDialogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ASCOM.LunaticAstro.FilterWheel.FilterWheelDriver.ViewModel"
             mc:Ignorable="d" Height="250">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TabControl Height="200" Width="480"
                SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem Header="Setup">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Top description -->
                            <TextBlock
                               TextWrapping="Wrap"
                               HorizontalAlignment="Left"
                               FontSize="14"><Run Text="Choose the "/><Run Language="en-gb" Text="COM port"/><Run Text=" that your filter wheel is connected to below. Use the Filter Settings tab to set names and offsets."/></TextBlock>

                            <!-- ASCOM logo -->
                            <Image Grid.Column="2"
                           HorizontalAlignment="Right"
                           Width="48"
                           Height="56"
                           Cursor="Hand"
                           Margin="0,0,0,10"
                           Source="pack://application:,,,/ASCOM.LunaticAstro.Nano.FilterWheel;component/Resources/ASCOM.png"
                           MouseLeftButtonUp="BrowseToAscom"/>
                        </Grid>
                        <!-- COM Port -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Comm Port" VerticalAlignment="Center" Width="80"/>
                            <ComboBox Width="180"
                      Margin="10,0,0,0"
                      ItemsSource="{Binding ComPorts}"
                      SelectedItem="{Binding SelectedComPort}" />
                        </StackPanel>

                        <!-- Trace checkbox -->
                        <CheckBox Grid.Row="2"
                  Content="Trace on"
                  Margin="90,10,0,0"
                  IsChecked="{Binding TraceEnabled}" />


                    </Grid>
                </TabItem>
                <TabItem Header="Filter Settings">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Margin="5" TextWrapping="Wrap" FontSize="14"><Run Text="Set the name and focus/position offsets for each filter. Changes are automatically saved to the filter wheel when you edit a cell."/></TextBlock>
                        <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Filters}"
                              SelectedItem="{Binding SelectedFilter}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False" VerticalAlignment="Stretch"
                              CellEditEnding="DataGrid_CellEditEnding"
                                  ToolTip="Changes made in the data grid are automatically saved to the filter wheel.">
                            <DataGrid.Columns>

                                <DataGridTextColumn Header="#" Binding="{Binding Index}" IsReadOnly="True"/>

                                <DataGridTextColumn Header="Name" Width="200"
                            Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                                <DataGridTextColumn Header="Focus Offset"
                            Binding="{Binding FocusOffset, UpdateSourceTrigger=PropertyChanged}"/>

                                <DataGridTextColumn Header="Position Offset"
                            Binding="{Binding PositionOffset, UpdateSourceTrigger=PropertyChanged}"/>

                                <DataGridTemplateColumn Header="Adjust">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <UniformGrid Rows="1" Columns="2" Margin="4,0,0,0">
                                                <Button Content="-" Command="{Binding DecrementOffsetCommand}" />
                                                <Button Content="+" Command="{Binding IncrementOffsetCommand}" />
                                            </UniformGrid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
            <!-- Buttons -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,5,10,5">
                <Button Width="80"
                        Height="28"
                        Margin="0,0,10,0"
                        Content="OK"
                        Command="{Binding OkCommand}" 
                        ToolTip="Keep any changes and close the dialog."/>

                <Button Width="80"
                        Height="28"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        ToolTip="Cancel any changes and close the dialog."/>
            </StackPanel>
        </Grid>
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
              IsHitTestVisible="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.Background>
                <SolidColorBrush Color="#40000000"/>
                <!-- semi-transparent dark overlay -->
            </Grid.Background>

            <Image x:Name="Spinner" Grid.Row="1"
                Source="pack://application:,,,/ASCOM.LunaticAstro.Nano.FilterWheel;component/Resources/FilterWheel.png
"              Width="64"
               Height="64"
               HorizontalAlignment="Center"
               VerticalAlignment="Center">
                <Image.RenderTransform>
                    <RotateTransform Angle="0" CenterX="32" CenterY="32"/>
                </Image.RenderTransform>
            </Image>
            <TextBlock Grid.Row="2" Text="{Binding BusyMessage}" 
                   HorizontalAlignment="Center" 
                   Margin="0,10,0,10"
                   FontSize="14"
                   Foreground="White"/>
        </Grid>
    </Grid>
</UserControl>